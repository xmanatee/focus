{
  "expo": {
    "name": "fucus",
    "slug": "fucus",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourbound.fucus",
      "appleTeamId": "569HBLNQPC",
      "buildNumber": "1",
      "infoPlist": {
        "NSFamilyControlsUsageDescription": "Fucus uses Screen Time to block the apps you choose during the focus blocks you create.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "splash": {
      "backgroundColor": "#F8F2E8",
      "resizeMode": "contain",
      "dark": {
        "backgroundColor": "#1A1510"
      }
    },
    "scheme": "fucus",
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.0"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "569HBLNQPC",
          "appGroup": "group.com.yourbound.fucus"
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/with-fucus-icloud"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.yourbound.fucus"
    }
  }
}
