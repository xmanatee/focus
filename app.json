{
  "expo": {
    "name": "fucus",
    "slug": "fucus",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourbound.fucus",
      "appleTeamId": "569HBLNQPC"
    },
    "scheme": "fucus",
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.0"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "569HBLNQPC",
          "appGroup": "group.com.yourbound.fucus"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
