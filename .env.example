# Public Convex endpoints (safe to commit; they already are in app.config)
CONVEX_DEPLOYMENT=dev:expert-walrus-588
EXPO_PUBLIC_CONVEX_URL=https://expert-walrus-588.eu-west-1.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://expert-walrus-588.eu-west-1.convex.site

# iOS Google OAuth client id from Google Cloud Console.
# Used by the native Google sign-in sheet (no web secret).
# Paste the value labeled "Client ID" on the iOS OAuth 2.0 client in Google
# Cloud Console -> APIs & Services -> Credentials.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
