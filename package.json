{
  "name": "focus-blocks",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check-lines": "node scripts/check-line-limit.mjs",
    "check-antipatterns": "node scripts/check-antipatterns.mjs",
    "check-deps": "npm ls",
    "screenshots": "node scripts/screenshots.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@nauverse/expo-cloud-settings": "^1.3.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "expo": "~52.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-haptics": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.0",
    "expo-symbols": "~0.2.2",
    "nativewind": "^4.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-device-activity": "^0.6.1",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/react": "~18.3.12",
    "knip": "^5.12.1",
    "lefthook": "^1.6.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "vitest": "^1.6.1"
  },
  "private": true
}
